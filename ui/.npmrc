# NPM security hardening for Watcher UI
# Never run lifecycle scripts during install (prevents postinstall exploits)
ignore-scripts=true

# Enforce strict SSL certificate checking
strict-ssl=true

# Only install exact versions from lockfile
ci=true

# Registry: use official npm registry only
registry=https://registry.npmjs.org/

# Disallow unpinned dependencies (requires lockfile)
package-lock=true

# Warn on deprecated packages (fail in CI)
engine-strict=true

# Prevent accidental publishes of this private package
access=restricted

# Audit level: fail builds on moderate or higher vulnerabilities
audit-level=moderate

# Fund and peer dependency warnings disabled (noise reduction)
fund=false
peer-deps=false
